{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a",
        "GRADLE_OPTS": "-Xmx4096m -XX:MaxMetaspaceSize=512m",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a",
        "GRADLE_OPTS": "-Xmx4096m -XX:MaxMetaspaceSize=512m"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
